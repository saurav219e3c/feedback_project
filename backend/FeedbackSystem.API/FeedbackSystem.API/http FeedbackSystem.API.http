@FeedbackSystem.API_HostAddress = http://localhost:5001
@token = 

############################################
# AUTHENTICATION ENDPOINTS
############################################

### 1. Login as Admin (Run this first to get token)
POST {{FeedbackSystem.API_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@local",
  "password": "Admin@123"
}

###

### 2. Register New User (Requires Admin token)
POST {{FeedbackSystem.API_HostAddress}}/api/auth/register
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "fullName": "John Doe",
  "email": "john.doe@example.com",
  "password": "Password@123",
  "roleName": "Employee"
}

###

############################################
# CATEGORY ENDPOINTS
############################################

### 3. Get All Categories
GET {{FeedbackSystem.API_HostAddress}}/api/categories
Accept: application/json

###

### 4. Get Category By ID
GET {{FeedbackSystem.API_HostAddress}}/api/categories/1
Accept: application/json

###

### 5. Create Category - Technical Skills
POST {{FeedbackSystem.API_HostAddress}}/api/categories
Content-Type: application/json

{
  "categoryName": "Technical Skills",
  "description": "Feedback related to technical abilities and expertise"
}

###

### 6. Create Category - Communication
POST {{FeedbackSystem.API_HostAddress}}/api/categories
Content-Type: application/json

{
  "categoryName": "Communication",
  "description": "Feedback on communication and collaboration skills"
}

###

### 7. Create Category - Leadership
POST {{FeedbackSystem.API_HostAddress}}/api/categories
Content-Type: application/json

{
  "categoryName": "Leadership",
  "description": "Feedback on leadership qualities and team management"
}

###

### 8. Create Category - Problem Solving
POST {{FeedbackSystem.API_HostAddress}}/api/categories
Content-Type: application/json

{
  "categoryName": "Problem Solving",
  "description": "Feedback on analytical and problem-solving abilities"
}

###

### 9. Update Category
PUT {{FeedbackSystem.API_HostAddress}}/api/categories/1
Content-Type: application/json

{
  "categoryName": "Technical Skills (Updated)",
  "description": "Updated description for technical skills feedback",
  "isActive": true
}

###

### 10. Delete Category
DELETE {{FeedbackSystem.API_HostAddress}}/api/categories/1

###

### 11. Test Duplicate Category Name (Should return 409 Conflict)
POST {{FeedbackSystem.API_HostAddress}}/api/categories
Content-Type: application/json

{
  "categoryName": "Communication",
  "description": "This should fail as name already exists"
}

###

############################################
# USER ENDPOINTS (Requires Admin Token)
############################################

### 12. Get All Users (Admin only)
GET {{FeedbackSystem.API_HostAddress}}/api/users
Accept: application/json
Authorization: Bearer {{token}}

###

### 13. Get User By ID (Admin only)
GET {{FeedbackSystem.API_HostAddress}}/api/users/1
Accept: application/json
Authorization: Bearer {{token}}

###

### 14. Create User - Manager (Admin only)
POST {{FeedbackSystem.API_HostAddress}}/api/users
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "fullName": "Jane Smith",
  "email": "jane.smith@example.com",
  "password": "Manager@123",
  "roleName": "Manager"
}

###

### 15. Create User - Employee (Admin only)
POST {{FeedbackSystem.API_HostAddress}}/api/users
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "fullName": "Bob Johnson",
  "email": "bob.johnson@example.com",
  "password": "Employee@123",
  "roleName": "Employee"
}

###

### 16. Update User (Admin only)
PUT {{FeedbackSystem.API_HostAddress}}/api/users/2
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "fullName": "Jane Smith Updated",
  "roleName": "Manager",
  "isActive": true
}

###

### 17. Delete User (Admin only)
DELETE {{FeedbackSystem.API_HostAddress}}/api/users/2
Authorization: Bearer {{token}}

###

############################################
# TESTING SCENARIOS
############################################

### 18. Test Login with Invalid Credentials
POST {{FeedbackSystem.API_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "invalid@example.com",
  "password": "WrongPassword"
}

###

### 19. Test Unauthorized Access (No Token)
GET {{FeedbackSystem.API_HostAddress}}/api/users
Accept: application/json

###

### 20. Test Get Non-Existent Category
GET {{FeedbackSystem.API_HostAddress}}/api/categories/9999
Accept: application/json

###

### 21. Test Update Non-Existent Category
PUT {{FeedbackSystem.API_HostAddress}}/api/categories/9999
Content-Type: application/json

{
  "categoryName": "Non-Existent",
  "description": "This should return 404",
  "isActive": true
}

###

### 22. Test Delete Non-Existent Category
DELETE {{FeedbackSystem.API_HostAddress}}/api/categories/9999

###

############################################
# QUICK REFERENCE
############################################

# DEFAULT CREDENTIALS:
# Email: admin@local
# Password: Admin@123

# ROLES:
# - Admin (full access)
# - Manager (management access)
# - Employee (basic access)

# TESTING WORKFLOW:
# 1. Run Login (endpoint 1) and copy the token
# 2. Replace {{token}} variable at the top with actual token
# 3. Test Categories (endpoints 3-11)
# 4. Test Users with Admin token (endpoints 12-17)
# 5. Test error scenarios (endpoints 18-22)

###