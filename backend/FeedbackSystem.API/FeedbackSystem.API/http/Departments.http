@FeedbackSystem.API_HostAddress = http://localhost:5001
@token = 

############################################
# DEPARTMENT ENDPOINTS
############################################

### 1. Get All Departments (Public - No Auth Required)
GET {{FeedbackSystem.API_HostAddress}}/api/departments
Accept: application/json

###

### 2. Get Department By ID
GET {{FeedbackSystem.API_HostAddress}}/api/departments/1
Accept: application/json

###

### 3. Create Department - Engineering (Admin only)
POST {{FeedbackSystem.API_HostAddress}}/api/departments
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "departmentName": "Engineering",
  "description": "Product engineering team"
}

###

### 4. Create Department - HR (Admin only)
POST {{FeedbackSystem.API_HostAddress}}/api/departments
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "departmentName": "Human Resources",
  "description": "HR department"
}

###

### 5. Create Department - Sales (Admin only)
POST {{FeedbackSystem.API_HostAddress}}/api/departments
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "departmentName": "Sales",
  "description": "Revenue team"
}

###

### 6. Update Department (Admin only)
PUT {{FeedbackSystem.API_HostAddress}}/api/departments/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "departmentName": "Engineering (Updated)",
  "description": "Updated description for engineering department",
  "isActive": true
}

###

### 7. Delete Department (Admin only)
DELETE {{FeedbackSystem.API_HostAddress}}/api/departments/1
Authorization: Bearer {{token}}

###

### 8. Test Duplicate Department Name (Should return 409 Conflict)
POST {{FeedbackSystem.API_HostAddress}}/api/departments
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "departmentName": "Engineering",
  "description": "This should fail as name already exists"
}

###

############################################
# USAGE NOTES
############################################

# Department IDs for reference (seeded by DbSeeder):
# 1 - General (default)
# 2 - Engineering
# 3 - HR
# 4 - Sales

# When creating/updating users, use departmentId from the above list
# Example: "departmentId": 2 (for Engineering)

###
