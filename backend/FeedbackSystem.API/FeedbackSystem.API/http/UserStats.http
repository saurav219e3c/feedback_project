@FeedbackSystem.API_HostAddress = http://localhost:5001
@token = 

############################################
# USER STATISTICS ENDPOINT
############################################

### 1. Get User Statistics (Admin only)
# Returns total users, active users, and inactive users count
GET {{FeedbackSystem.API_HostAddress}}/api/users/stats
Authorization: Bearer {{token}}
Accept: application/json

###

### 2. Test Unauthorized Access (No Token)
# Should return 401 Unauthorized
GET {{FeedbackSystem.API_HostAddress}}/api/users/stats
Accept: application/json

###

############################################
# EXPECTED RESPONSE FORMAT
############################################

# Success Response (200 OK):
# {
#   "totalUsers": 15,
#   "activeUsers": 12,
#   "inactiveUsers": 3
# }

# Unauthorized Response (401):
# {
#   "type": "https://tools.ietf.org/html/rfc7235#section-3.1",
#   "title": "Unauthorized",
#   "status": 401
# }

############################################
# AUTHORIZATION
############################################

# Required Role: Admin
# Endpoint: GET /api/users/stats

############################################
# USE CASES
############################################

# 1. Dashboard Widget - Display total users count
# 2. User Management - Monitor active vs inactive users
# 3. System Health - Track user growth and activity
# 4. Reporting - Generate user statistics reports

############################################
# CALCULATION
############################################

# totalUsers = All users in the system
# activeUsers = Users with IsActive = true
# inactiveUsers = totalUsers - activeUsers

###
