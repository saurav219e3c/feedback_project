@FeedbackSystem.API_HostAddress = http://localhost:5001

############################################
# PUBLIC REGISTRATION ENDPOINT
############################################

### 1. Public Registration - Employee in Engineering Department
# No authentication required - anyone can register
# Role is always forced to "Employee" regardless of input
POST {{FeedbackSystem.API_HostAddress}}/api/auth/register-public
Content-Type: application/json

{
  "fullName": "Alice Johnson",
  "email": "alice.johnson@example.com",
  "password": "SecurePass@123",
  "departmentId": 2
}

###

### 2. Public Registration - Employee in HR Department
POST {{FeedbackSystem.API_HostAddress}}/api/auth/register-public
Content-Type: application/json

{
  "fullName": "Bob Smith",
  "email": "bob.smith@example.com",
  "password": "SecurePass@456",
  "departmentId": 3
}

###

### 3. Public Registration - Employee in Sales Department
POST {{FeedbackSystem.API_HostAddress}}/api/auth/register-public
Content-Type: application/json

{
  "fullName": "Charlie Davis",
  "email": "charlie.davis@example.com",
  "password": "SecurePass@789",
  "departmentId": 4
}

###

### 4. Test Duplicate Email (Should return 400 Bad Request)
POST {{FeedbackSystem.API_HostAddress}}/api/auth/register-public
Content-Type: application/json

{
  "fullName": "Duplicate User",
  "email": "alice.johnson@example.com",
  "password": "SecurePass@123",
  "departmentId": 2
}

###

### 5. Test Invalid Department (Should return 400 Bad Request)
POST {{FeedbackSystem.API_HostAddress}}/api/auth/register-public
Content-Type: application/json

{
  "fullName": "Test User",
  "email": "test.invalid@example.com",
  "password": "SecurePass@123",
  "departmentId": 999
}

###

### 6. Test Weak Password (Should return 400 Bad Request - Validation)
POST {{FeedbackSystem.API_HostAddress}}/api/auth/register-public
Content-Type: application/json

{
  "fullName": "Test User",
  "email": "test.weak@example.com",
  "password": "123",
  "departmentId": 2
}

###

### 7. Test Invalid Email Format (Should return 400 Bad Request - Validation)
POST {{FeedbackSystem.API_HostAddress}}/api/auth/register-public
Content-Type: application/json

{
  "fullName": "Test User",
  "email": "invalid-email",
  "password": "SecurePass@123",
  "departmentId": 2
}

###

############################################
# EXPECTED RESPONSE FORMAT
############################################

# Success Response (201 Created):
# {
#   "userId": 5,
#   "fullName": "Alice Johnson",
#   "email": "alice.johnson@example.com",
#   "role": "Employee",  ? Always "Employee"
#   "departmentId": 2,
#   "departmentName": "Engineering",
#   "isActive": true,
#   "createdAt": "2024-12-15T10:00:00Z"
# }

# Error Response (400 Bad Request):
# {
#   "message": "Email already exists."
# }
# OR
# {
#   "message": "Department not found or inactive."
# }

############################################
# DEPARTMENT IDS (FROM SEEDER)
############################################

# 1 - General (default)
# 2 - Engineering
# 3 - HR
# 4 - Sales

############################################
# KEY FEATURES
############################################

# ? No authentication required - public endpoint
# ? Role is ALWAYS forced to "Employee" (server-side)
# ? Department must exist and be active
# ? Email must be unique
# ? Password validation (min 6 characters)
# ? Email format validation
# ? Full name required (max 50 chars)

############################################
# SECURITY NOTES
############################################

# 1. Users registered via this endpoint are always "Employee" role
# 2. Admin/Manager roles can only be assigned via /api/auth/register (Admin auth required)
# 3. All users start as "isActive: true"
# 4. Passwords are hashed using bcrypt before storage
# 5. Department must be validated before user creation

###
