@FeedbackSystem.API_HostAddress = http://localhost:5001
@token = 

############################################
# CATEGORY STATISTICS ENDPOINTS
############################################

### 1. Get Feedback Statistics by Category
# Returns count of feedback grouped by each category
# Admin: Can filter by any department
# Manager: Auto-scoped to their department
GET {{FeedbackSystem.API_HostAddress}}/api/admin/feedback/by-category
Authorization: Bearer {{token}}
Accept: application/json

###

### 2. Get Feedback by Category with Date Range
GET {{FeedbackSystem.API_HostAddress}}/api/admin/feedback/by-category?from=2024-01-01&to=2024-12-31
Authorization: Bearer {{token}}
Accept: application/json

###

### 3. Get Feedback by Category for Specific Department
GET {{FeedbackSystem.API_HostAddress}}/api/admin/feedback/by-category?departmentId=1
Authorization: Bearer {{token}}
Accept: application/json

###

### 4. Get Feedback by Category for Specific User
# Shows categories where user was either giver or receiver
GET {{FeedbackSystem.API_HostAddress}}/api/admin/feedback/by-category?userId=2
Authorization: Bearer {{token}}
Accept: application/json

###

### 5. Get Recognition Statistics by Category
# Returns count of recognitions grouped by each category
GET {{FeedbackSystem.API_HostAddress}}/api/admin/recognitions/by-category
Authorization: Bearer {{token}}
Accept: application/json

###

### 6. Get Recognition by Category with Date Range
GET {{FeedbackSystem.API_HostAddress}}/api/admin/recognitions/by-category?from=2024-01-01&to=2024-12-31
Authorization: Bearer {{token}}
Accept: application/json

###

### 7. Get Recognition by Category for Specific Department
GET {{FeedbackSystem.API_HostAddress}}/api/admin/recognitions/by-category?departmentId=2
Authorization: Bearer {{token}}
Accept: application/json

###

### 8. Get Recognition by Category for Specific User
GET {{FeedbackSystem.API_HostAddress}}/api/admin/recognitions/by-category?userId=3
Authorization: Bearer {{token}}
Accept: application/json

###

### 9. Combined Query - Feedback by Category (Date + Dept + User)
GET {{FeedbackSystem.API_HostAddress}}/api/admin/feedback/by-category?from=2024-01-01&to=2024-12-31&departmentId=1&userId=2
Authorization: Bearer {{token}}
Accept: application/json

###

############################################
# EXPECTED RESPONSE FORMATS
############################################

# Feedback by Category Response:
# [
#   {
#     "categoryId": 1,
#     "categoryName": "Technical Skills",
#     "feedbackCount": 45,
#     "latestFeedbackAt": "2024-12-15T10:30:00Z"
#   },
#   {
#     "categoryId": 2,
#     "categoryName": "Communication",
#     "feedbackCount": 38,
#     "latestFeedbackAt": "2024-12-14T15:20:00Z"
#   }
# ]

# Recognition by Category Response:
# [
#   {
#     "categoryId": 1,
#     "categoryName": "Outstanding Performance",
#     "recognitionCount": 25,
#     "latestRecognitionAt": "2024-12-15T10:30:00Z"
#   },
#   {
#     "categoryId": 2,
#     "categoryName": "Team Player",
#     "recognitionCount": 18,
#     "latestRecognitionAt": "2024-12-14T15:20:00Z"
#   }
# ]

############################################
# QUERY PARAMETERS
############################################

# from (DateTime?): Start date for filtering
# to (DateTime?): End date for filtering
# departmentId (int?): Filter by department (Admin only can use any, Manager auto-scoped)
# userId (int?): Filter by specific user (as giver or receiver)

############################################
# AUTHORIZATION
############################################

# Required Roles: Admin, Manager
# Manager: Auto-scoped to their department
# Admin: Full system access

###
