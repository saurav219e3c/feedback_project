@FeedbackSystem.API_HostAddress = http://localhost:5001
@token = 

############################################
# AUTHENTICATION ENDPOINTS (WITH DEPARTMENT)
############################################

### 1. Login as Admin (Run this first to get token)
POST {{FeedbackSystem.API_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@local",
  "password": "Admin@123"
}

###

### 2. Register New User with Department (Requires Admin token)
POST {{FeedbackSystem.API_HostAddress}}/api/auth/register
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "fullName": "John Doe",
  "email": "john.doe@example.com",
  "password": "Password@123",
  "roleName": "Employee",
  "departmentId": 2
}

###

############################################
# USER ENDPOINTS (WITH DEPARTMENT)
############################################

### 3. Get All Users (Admin only) - Now includes department info
GET {{FeedbackSystem.API_HostAddress}}/api/users
Accept: application/json
Authorization: Bearer {{token}}

###

### 4. Get User By ID (Admin only) - Now includes department info
GET {{FeedbackSystem.API_HostAddress}}/api/users/1
Accept: application/json
Authorization: Bearer {{token}}

###

### 5. Create User - Manager in HR Department (Admin only)
POST {{FeedbackSystem.API_HostAddress}}/api/users
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "fullName": "Jane Smith",
  "email": "jane.smith@example.com",
  "password": "Manager@123",
  "roleName": "Manager",
  "departmentId": 3
}

###

### 6. Create User - Employee in Engineering (Admin only)
POST {{FeedbackSystem.API_HostAddress}}/api/users
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "fullName": "Bob Johnson",
  "email": "bob.johnson@example.com",
  "password": "Employee@123",
  "roleName": "Employee",
  "departmentId": 2
}

###

### 7. Update User (Admin only) - Can change department
PUT {{FeedbackSystem.API_HostAddress}}/api/users/2
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "fullName": "Jane Smith Updated",
  "roleName": "Manager",
  "departmentId": 4,
  "isActive": true
}

###

### 8. Delete User (Admin only)
DELETE {{FeedbackSystem.API_HostAddress}}/api/users/2
Authorization: Bearer {{token}}

###

############################################
# TESTING SCENARIOS
############################################

### 9. Test Register with Invalid Department (Should return 400/404)
POST {{FeedbackSystem.API_HostAddress}}/api/auth/register
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "fullName": "Test User",
  "email": "test@example.com",
  "password": "Password@123",
  "roleName": "Employee",
  "departmentId": 999
}

###

### 10. Test Login with Invalid Credentials
POST {{FeedbackSystem.API_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "invalid@example.com",
  "password": "WrongPassword"
}

###

############################################
# DEPARTMENT IDS (SEEDED BY DEFAULT)
############################################

# 1 - General (default department)
# 2 - Engineering
# 3 - HR
# 4 - Sales

